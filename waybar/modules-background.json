{

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    // "format": "< %g >",
    // "format_focused" : "< %g в—Ҹ >",
    "format-icons": {
      "1": "п„ ",
      "2": "пү©",
      "3": "пҒ»",
      "4": "п„Ў",
      "5": "п…Ә",
      "6": "пӮҶ",
      "7": "пӮӣ",
      "8": "пҮҖ",
      "9": "пҶҳ",
      "10": "п„‘"
    }
  },
  "mpd": {
    "tooltip": true,
    "tooltip-format": "{artist} - {album} - {title} - Total Time : {totalTime:%M:%S}",
    "format": "пӢІ {elapsedTime:%M:%S}",
    "format-disconnected": "вҡ   Disconnected",
    "format-stopped": "пӢІ Not Playing",
    "on-click": "mpc toggle",
    "state-icons": {
      "playing": "пҒӢ",
      "paused": "пЈЈ"
    }
  },
  "mpd#2": {
    "format": "пҒҲ",
    "format-disconnected": "пҒҲ",
    "format-paused": "пҒҲ",
    "format-stopped": "пҒҲ",
    // Commands to execute on events
    "on-click": "mpc -q pause && mpc -q prev && mpc -q start"
  },
  "mpd#3": {
    "interval": 1,
    "format": "{stateIcon}",
    "format-disconnected": "пҒӢ",
    "format-paused": "{stateIcon}",
    "format-stopped": "пҒӢ",
    "state-icons": {
      "paused": "пҒӢ",
      "playing": "пҒҢ"
    },
    // Commands to execute on events
    "on-click": "mpc toggle"
  },
  "mpd#4": {
    "format": "пҒ‘",
    "format-disconnected": "пҒ‘",
    "format-paused": "пҒ‘",
    "format-stopped": "пҒ‘",
    // Commands to execute on events
    "on-click": "mpc -q pause && mpc -q next && mpc -q start"
  },
  "custom/swap": {
    "on-click": "~/.config/waybar/scripts/swap.sh",
    "format": "Bg пҲ… ",
    "tooltip": true,
    "tooltip-format": "Swap between waybar Themes"
  },
  "custom/mpd": {
    "format": "пҖҒ {title} - {artist}",
    "interval": 5,
    "exec": "mpc current --format='\"title\":\"%title%\",\"artist\":\"%artist%\"'"
  },
  "custom/cava-internal": {
    "exec": "sh ~/.config/waybar/scripts/Cava.sh",
    "format": "{}",
    "tooltip": false,
    "on-click": "swaymsg `reload & pkill waybar & waybar",
    "layer": "below",
    "output": "all"
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true,
    "format": "<span color=\"#24273a\" style=\"italic\">{}</span>"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пҸҒ",
      "deactivated": "пҖЈ"
    }
  },
  "tray": {
    // "icon-size": 14,
    "spacing": 5
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	"months": "<span color='#bb9af7'><b>{}</b></span>",  // Purple
	"days": "<span color='#7aa2f7'><b>{}</b></span>",    // Blue
	"weeks": "<span color='#9ece6a'><b>W{}</b></span>",  // Green
	"weekdays": "<span color='#e0af68'><b>{}</b></span>",// Yellow
	"today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b | %I:%M %p}", //12 hour format
    "format-alt": "п„і  {:%Y-%m-%d пҖ— %H:%M:%S}",
    "interval": 1
  },

  // System
  "custom/system": {
    "format": "о‘і",
    "tooltip": false
  },
  "cpu": {
    "format": "пӢӣ {usage: >3}%",
    "on-click": "ghostty -e htop"
  },
  "memory": {
    "format": "п”ё {: >3}%",
    "on-click": "ghostty -e htop"
  },
  "temperature": {
    "thermal-zone": 4,
    // "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}В°C пӢҮ",
    "format": "пӢү  {temperatureC}В°C"
  },
  // Harddisc space used
  "disk": {
    // "interval": 30,
    "format": "пӮ  {percentage_used}% ",
    "path": "/",
    //"on-click": "ghostty -e htop"
  }, 
    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "memory"
            // "backlight",
            //"sway/language"
        ]
    },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent: >3}%",
    // "format-icons": ["пҶ…", "п„‘"],
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    // "on-scroll-down": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
    "on-scroll-up": "brightnessctl -c backlight set +5%",
    // "on-scroll-up": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
    "on-click": ""
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    "format-charging": "п—§  {capacity}%",
    "format-plugged": "пҮҰ  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
  },
  "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format": "вҡ   Disabled",
    "format-wifi": "пҮ«  {essid}",
    // "format-ethernet": "пғҒ {ifname}: {ipaddr}/{cidr}",
    "format-ethernet": "пғҒ  Wired",
    "format-disconnected": "вҡ   Disconnected",
    "tooltip-format": "пһ– {ifname} via {gwaddri}",
    "tooltip-format-wifi": "пҮ«   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пғҒ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "вҡ   Disconnected",
    // "on-click": "ghostty -e nmtui"
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    // "scroll-step": 1,
    "format": "{icon} {volume: >3}%",
    "format-bluetooth": "{icon} {volume: >3}%",
    "format-muted": "пҡ©",
    "format-icons": {
      "headphones": "пҖҘ",
      "handsfree": "пҖҘ",
      "headset": "пҖҘ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": ["пҖ§", "пҖЁ"]
    },
    "on-click": "pavucontrol",
    // "on-scroll-up": "pamixer -ui 2 && pamixer --get-volume > $SWAYSOCK.wob",
    // "on-scroll-down": "pamixer -ud 2 && pamixer --get-volume > $SWAYSOCK.wob"
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },
  "custom/pacman": {
    "format": "пҶҮ {}",
    "interval": 7200, // every two hours
    "exec": "i=$(checkupdates); echo \"$i\" |wc -l; echo \"$i\" |column -t |tr '\n' '\r'", // # of updates and tooltip details
    "exec-if": "exit 0", // always run; consider advanced run conditions
    "on-click": "ghostty -e sudo pacman -Syu", // update system
    "signal": 8
  },
  "custom/power": {
    "format": "вҸ»",
    // "on-click": "wlogout -p layer-shell",
    "on-click": "~/.config/rofi/powermenu/powermenu.sh",
    "tooltip": false
  },
  "custom/keyboard-layout": {
    "exec": "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4",
    // Interval set only as a fallback, as the value is updated by signal
    "interval": 1,
    "format": "п„ң  {}", // Icon: keyboard
    // Signal sent by Sway key binding (~/.config/sway/key-bindings)
    "signal": 1, // SIGHUP
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/keyhint.sh"
  },
  "custom/launcher": {
    "format": "пҖ•",
    "on-click": "rofi -show drun -replace",
    "tooltip": false
  }
}
